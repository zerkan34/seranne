:root {
  --ink: #1A1916;
  --ink-soft: #3A3833;
  --mute: #7B7770;
  --paper: #F4F0E6;
  --slab: rgba(244, 240, 230, 0.92);
  --slab-edge: rgba(26, 25, 22, 0.10);
  --rule: rgba(26, 25, 22, 0.14);
  --gold: #A88B4B;
}

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  overflow-x: hidden;
  scroll-behavior: smooth;
  scroll-padding-top: 80px;
}

body {
  color: var(--ink);
  overflow-x: hidden;
  font: 400 15px/1.7 'Inter Tight', ui-sans-serif, system-ui, sans-serif;
  -webkit-font-smoothing: antialiased;
  letter-spacing: -0.005em;
  background: #EFEBE0 url('/marble.jpg') center top / 100% auto repeat-y fixed;
}

@media (max-width: 760px) {
  body {
    background-attachment: scroll;
    background-size: 170% auto;
  }
}

img { display: block; max-width: 100%; }
a { color: inherit; text-decoration: none; }
button {
  font: inherit; color: inherit; background: none; border: 0; cursor: pointer; padding: 0;
}
::selection { background: var(--ink); color: var(--paper); }
