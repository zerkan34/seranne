import { motion } from 'motion/react';
import { ease } from '../motion';
import styles from './Savoir.module.css';

const steps = [
  { n: '01', h: 'Le bloc', p: 'Sélection en carrière de Carrare. Un seul bloc par pièce, pour la continuité du veinage.' },
  { n: '02', h: 'La taille', p: 'Sculpté au ciseau, poli à la main jusqu\'au velours de la pierre. Tolérances au dixième.' },
  { n: '03', h: 'La gravure', p: 'Incisions comblées à la feuille d\'or, brunies, scellées. La signature devient indélébile.' },
];

export default function Savoir() {
  return (
    <section className={styles.section} id="s-savoir" data-piece-id="savoir">
      <div className={styles.wrap}>
        <motion.div
          className={styles.lab}
          initial={{ opacity: 0, y: 12 }}
          whileInView={{ opacity: 1, y: 0 }}
          viewport={{ once: true, margin: '-15% 0px' }}
          transition={{ duration: 0.7, ease: ease.out }}
        >
          <span>007 / 007 — Atelier</span>
          <b>Du bloc à l'or</b>
        </motion.div>

        <motion.div
          className={styles.card}
          initial={{ opacity: 0, y: 40 }}
          whileInView={{ opacity: 1, y: 0 }}
          viewport={{ once: true, margin: '-10% 0px' }}
          transition={{ duration: 1.0, ease: ease.out }}
        >
          <h3 className={styles.h3}>Du bloc à l'<em>or</em>.</h3>

          <motion.ol
            className={styles.list}
            initial="hidden"
            whileInView="visible"
            viewport={{ once: true, margin: '-10% 0px' }}
            variants={{ hidden: {}, visible: { transition: { staggerChildren: 0.15, delayChildren: 0.3 } } }}
          >
            {steps.map(s => (
              <motion.li
                key={s.n}
                variants={{
                  hidden: { opacity: 0, y: 20, filter: 'blur(4px)' },
                  visible: { opacity: 1, y: 0, filter: 'blur(0px)', transition: { duration: 0.8, ease: ease.out } },
                }}
              >
                <span className={styles.num}>{s.n}</span>
                <div>
                  <h4>{s.h}</h4>
                  <p>{s.p}</p>
                </div>
              </motion.li>
            ))}
          </motion.ol>
        </motion.div>
      </div>
    </section>
  );
}
